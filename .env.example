# Radarr Configuration
RADARR_URL=http://localhost:7878
RADARR_API_KEY=your_radarr_api_key_here

# TMDB Configuration (get free key from https://www.themoviedb.org/signup)
TMDB_API_KEY=your_tmdb_api_key_here

# Sync Settings
DAILY_LIMIT=5
SYNC_TIME=02:00
HIDE_FUTURE_RELEASES=true

# Optional: Plex (for verification only, not required)
PLEX_URL=
PLEX_TOKEN=

# App Settings
LOG_LEVEL=INFO
PORT=7117